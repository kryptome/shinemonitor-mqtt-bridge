# Shinemonitor credentials
# Replace these with your actual details from ShineMonitor
SHINEMONITOR_USERNAME=yourusername
SHINEMONITOR_PASSWORD=yourpassword
SHINEMONITOR_COMPANY_KEY=your_company_key_here

# Plant and device details
SHINEMONITOR_PLANT_ID=1234567
SHINEMONITOR_PN=your_datalogger_serial_or_unique_id     # PN = Datalogger Serial Number / unique ID
SHINEMONITOR_SN=your_inverter_serial_number             # SN = Inverter Serial Number
SHINEMONITOR_DEV_CODE=your_dev_code

# MQTT broker (point this to your Home Assistant or Mosquitto)
MQTT_BROKER=tcp://localhost:1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_CLIENT_ID=shinemonitor-bridge

# How often to fetch fresh data from ShineMonitor
POLL_INTERVAL=30s

# Log level (debug / info / warn / error)
LOG_LEVEL=info