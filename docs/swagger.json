{
    "swagger": "2.0",
    "info": {
        "description": "Bridge service exposing ShineMonitor solar metrics seamlessly via standard REST endpoints and pushing to MQTT.",
        "title": "ShineMonitor MQTT Bridge API",
        "contact": {
            "name": "Piyush Mishra"
        },
        "version": "1.0"
    },
    "paths": {
        "/dashboard": {
            "get": {
                "description": "Provides full metadata and raw readings about the plant including efficiency and cfValue",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Live Data"
                ],
                "summary": "Get detailed dashboard",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/shinemonitor.WebQueryPlant"
                        }
                    }
                }
            }
        },
        "/now": {
            "get": {
                "description": "Gets the immediate live power output of the plant",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Live Data"
                ],
                "summary": "Get current power",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/shinemonitor.EnergyNowResponse"
                        }
                    }
                }
            }
        },
        "/plant": {
            "get": {
                "description": "Grabs static configuration, address and nominal metrics for the plant",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Meta"
                ],
                "summary": "Get plant details",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/shinemonitor.PlantInfoResponse"
                        }
                    }
                }
            }
        },
        "/status": {
            "get": {
                "description": "Fetches the current online/offline status of the inverter",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Live Data"
                ],
                "summary": "Get device status",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/shinemonitor.StatusResponse"
                        }
                    }
                }
            }
        },
        "/summary": {
            "get": {
                "description": "Gets the today, month, year, and total energy production",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Live Data"
                ],
                "summary": "Get energy summary",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/shinemonitor.EnergySummaryResponse"
                        }
                    }
                }
            }
        },
        "/timeline": {
            "get": {
                "description": "Fetches historical energy production charts for day, month, year, or total metrics",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Historical"
                ],
                "summary": "Get energy timeline",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Date for historical records depending on timeframe (YYYY-MM-DD, YYYY-MM, or YYYY)",
                        "name": "date",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/shinemonitor.EnergyTimelineResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "shinemonitor.EnergyNowResponse": {
            "type": "object",
            "properties": {
                "Energy": {
                    "type": "string"
                },
                "Error": {
                    "type": "string"
                },
                "TimeStamp": {
                    "type": "string"
                },
                "Unit": {
                    "type": "string"
                }
            }
        },
        "shinemonitor.EnergySummaryResponse": {
            "type": "object",
            "properties": {
                "Error": {
                    "type": "string"
                },
                "Month": {
                    "type": "string"
                },
                "Today": {
                    "type": "string"
                },
                "Total": {
                    "type": "string"
                },
                "Unit": {
                    "type": "string"
                },
                "Year": {
                    "type": "string"
                }
            }
        },
        "shinemonitor.EnergyTimelineResponse": {
            "type": "object",
            "properties": {
                "TimeStamp": {
                    "type": "string"
                },
                "Unit": {
                    "type": "string"
                },
                "Value": {
                    "type": "string"
                }
            }
        },
        "shinemonitor.PlantAddress": {
            "type": "object",
            "properties": {
                "city": {
                    "type": "string"
                },
                "country": {
                    "type": "string"
                }
            }
        },
        "shinemonitor.PlantInfoResponse": {
            "type": "object",
            "properties": {
                "address": {
                    "$ref": "#/definitions/shinemonitor.PlantAddress"
                },
                "gridConnectionDate": {
                    "type": "string"
                },
                "installDate": {
                    "type": "string"
                },
                "profit": {
                    "$ref": "#/definitions/shinemonitor.PlantProfit"
                }
            }
        },
        "shinemonitor.PlantProfit": {
            "type": "object",
            "properties": {
                "totalProfit": {
                    "type": "string"
                },
                "totalProfitValue": {
                    "type": "string"
                }
            }
        },
        "shinemonitor.StatusResponse": {
            "type": "object",
            "properties": {
                "Error": {
                    "type": "string"
                },
                "Status": {
                    "type": "string"
                }
            }
        },
        "shinemonitor.WebQueryPlant": {
            "type": "object",
            "properties": {
                "cfValue": {
                    "type": "string"
                },
                "energy": {
                    "type": "string"
                },
                "energyMonth": {
                    "type": "string"
                },
                "energyTotal": {
                    "type": "string"
                },
                "energyYear": {
                    "type": "string"
                },
                "lts": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "nominalPower": {
                    "type": "string"
                },
                "outputPower": {
                    "type": "string"
                },
                "pid": {
                    "type": "integer"
                },
                "powerEfficiency": {
                    "type": "string"
                },
                "status": {
                    "type": "integer"
                }
            }
        }
    }
}